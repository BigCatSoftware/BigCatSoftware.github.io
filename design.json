{
  "$schema": "https://bigcatsoftware.github.io/design-schema.json",
  "version": "2.0.0",
  "name": "BigCatSoftware Portfolio Design System",
  "philosophy": "playful-tech",
  "intendedFeelings": ["intrigued", "warmth"],

  "tokens": {
    "color": {
      "bg":         { "value": "#eff1f5", "name": "Latte Base",     "role": "Primary page background" },
      "surface":    { "value": "#ccd0da", "name": "Latte Surface0", "role": "Cards, panels, elevated content" },
      "surface2":   { "value": "#bcc0cc", "name": "Latte Surface1", "role": "Borders, dividers, raised slabs" },
      "text":       { "value": "#4c4f69", "name": "Latte Text",     "role": "Body and heading copy" },
      "textMuted":  { "value": "#6c6f85", "name": "Latte Subtext0", "role": "Secondary copy, captions, kickers" },
      "accent":     { "value": "#7287fd", "name": "Latte Lavender", "role": "Primary accent, links, CTAs, key highlights, X piece in tic tac toe" },
      "accent2":    { "value": "#fe640b", "name": "Latte Peach",    "role": "Secondary accent, AI O piece, verify button on Lavender panel" },
      "border":     { "value": "#bcc0cc", "name": "Latte Surface1", "role": "Component borders (same value as surface2 by intent)" },
      "focusRing":  { "value": "#7287fd", "name": "Lavender",       "role": "Keyboard focus indicator" }
    },

    "font": {
      "display": {
        "family": "Newsreader",
        "fallback": ["Georgia", "Times New Roman", "serif"],
        "axes": ["opsz", "wght"],
        "role": "Section headings, hero display type, lead paragraphs"
      },
      "body": {
        "family": "Inter",
        "fallback": ["system-ui", "-apple-system", "sans-serif"],
        "role": "Body copy, paragraphs, button labels, captions"
      },
      "mono": {
        "family": "JetBrains Mono",
        "fallback": ["ui-monospace", "SFMono-Regular", "monospace"],
        "role": "Kickers, credential IDs, technical accents, code"
      }
    },

    "scale": {
      "displayHero":      { "size": "clamp(2.5rem, 5vw, 4.5rem)", "weight": 700, "tracking": "-0.02em", "lineHeight": 1.15 },
      "displayHeading":   { "size": "clamp(2.5rem, 4vw, 3.75rem)", "weight": 600, "tracking": "-0.01em", "lineHeight": 1.15 },
      "lead":             { "size": "clamp(1.25rem, 1.6vw, 1.5rem)", "weight": 400, "lineHeight": 1.7 },
      "body":             { "size": "1rem", "weight": 400, "lineHeight": 1.7 },
      "bodyLarge":        { "size": "1.125rem", "weight": 400, "lineHeight": 1.75 },
      "kicker":           { "size": "0.875rem", "weight": 500, "tracking": "0.22em", "transform": "uppercase" },
      "heroKicker":       { "size": "1.5rem",   "weight": 500, "tracking": "0.22em", "transform": "uppercase" },
      "credentialCode":   { "size": "clamp(2rem, 4vw, 3rem)", "weight": 500, "tracking": "0.05em" },
      "caption":          { "size": "0.875rem", "weight": 400 }
    },

    "spacing": {
      "sectionPaddingAiry":     { "value": "py-32 md:py-44", "appliesTo": ["Hero", "Credentials"] },
      "sectionPaddingBalanced": { "value": "py-24 md:py-28", "appliesTo": ["About", "FeaturedWork", "TicTacToe", "Contact"] },
      "interSectionGap":        { "value": "none", "note": "Sections own their own vertical padding; no extra gap between them" },
      "componentGap":           { "value": "space-y-6 to space-y-10", "note": "Stacked children within a component" },
      "longFormRowGap":         { "value": "space-y-20", "note": "Featured Work long-form list rows" }
    },

    "radius": {
      "sm":  "6px",
      "md":  "10px",
      "lg":  "14px",
      "xl":  "16px",
      "2xl": "24px"
    },

    "shadow": {
      "soft":       "0 2px 8px rgba(76, 79, 105, 0.06), 0 1px 2px rgba(76, 79, 105, 0.04)",
      "lifted":     "0 8px 24px rgba(76, 79, 105, 0.08), 0 2px 6px rgba(76, 79, 105, 0.05)",
      "accentGlow": "0 12px 36px rgba(114, 135, 253, 0.25), 0 2px 8px rgba(114, 135, 253, 0.12)",
      "innerSeat":  "inset 0 1px 0 rgba(255, 255, 255, 0.6)"
    },

    "motion": {
      "duration": {
        "instant": "0ms",
        "fast":    "180ms",
        "base":    "280ms",
        "medium":  "450ms",
        "slow":    "600ms",
        "ambient": "20000ms"
      },
      "easing": {
        "smoothOut":      "cubic-bezier(0.22, 1, 0.36, 1)",
        "snappy":         "cubic-bezier(0.34, 1.56, 0.64, 1)",
        "linear":         "linear",
        "springGentle":   { "type": "spring", "stiffness": 200, "damping": 24 },
        "springBouncy":   { "type": "spring", "stiffness": 300, "damping": 18 }
      },
      "respectReducedMotion": true
    }
  },

  "sectionApplicationRules": {
    "rule": "One section gets the bold Lavender panel: Credentials. All others use Lavender as accent on neutral Base.",
    "perSection": {
      "Hero":         { "background": "bg",          "accentUse": "Primary CTA fill, name kicker, ambient gradient",   "density": "airy" },
      "About":        { "background": "bg",          "accentUse": "Section heading, italicized phrases",               "density": "balanced" },
      "FeaturedWork": { "background": "bg",          "accentUse": "Card hover borders, View source links, BNB tag",   "density": "balanced" },
      "TicTacToe":    { "background": "bg",          "accentUse": "Player X, winning tile pulse, particle bursts",     "density": "balanced" },
      "Credentials":  { "background": "accent",      "accentUse": "Full Lavender panel; Peach for verify button",     "density": "airy" },
      "Contact":      { "background": "bg",          "accentUse": "Social link hover states",                          "density": "balanced" },
      "Footer":       { "background": "bg",          "accentUse": "None; muted text only",                             "density": "minimal" }
    }
  },

  "components": {
    "Hero": {
      "layout": "asymmetric",
      "structure": {
        "mdAndUp":  "two-column-grid: portrait-left ~45% / text-right ~55%",
        "mobile":   "stacked: portrait above text"
      },
      "portrait": {
        "src":      "/tiger_graduation_square_crop.jpg",
        "alt":      "Tiger Schueler receiving his diploma at UW Tacoma graduation.",
        "radius":   "2xl",
        "border":   "1px solid var(--color-border)",
        "shadow":   "lifted",
        "rotation": "-2deg",
        "maxWidth": "480px"
      },
      "text": {
        "kicker":     { "content": "TIGER SCHUELER", "style": "heroKicker", "color": "text" },
        "heading":    { "content": "Building durable software in C# and .NET.", "style": "displayHero", "color": "text" },
        "subheading": { "content": "Data Engineer at BNBuilders, Pacific Northwest.", "style": "lead", "color": "textMuted" },
        "ctas": [
          { "label": "View Work",     "href": "#work",    "style": "filled-accent",   "icon": "ArrowRight" },
          { "label": "Get In Touch",  "href": "#contact", "style": "ghost-outline",   "icon": null }
        ]
      },
      "ambient": {
        "type":     "radial-gradient",
        "from":     "accent",
        "to":       "accent2",
        "opacity":  0.18,
        "motion":   "drift on 20s loop via animated background-position"
      }
    },

    "About": {
      "layout":  "two-column-grid: heading-left max-content / prose-right max-w-2xl",
      "heading": { "content": "About", "style": "displayHeading" },
      "prose": [
        "I'm a Data Engineer in the Pacific Northwest. By day I'm in C# and T-SQL, building production data infrastructure at BNBuilders. The current main project is a .NET 10 ETL platform I built from scratch to move hundreds of millions of rows a day from Oracle ERP into Azure SQL.",
        "Background: B.S. in Computer Science & Systems from UW Tacoma with a math minor. Before that, four years in the Navy: Aviation Ordnance and Mount Captain on a .50 cal crew aboard USS Nimitz, deployed April 2020 to March 2021. And a few years before that, teaching martial arts (3rd Dan ITF black belt).",
        "Off the clock, I'm a husband and father of two. I'm a Christian; I read scripture, theology, and the church fathers, and keep a steady stack of programming and software books going on the side. When there's time left, I'm either picking up MonoGame to build a hobby game in C# or replaying old Nintendo games on the Switch."
      ],
      "motion": "fade-up stagger on scroll (heading, then each paragraph), 80ms stagger"
    },

    "FeaturedWork": {
      "layout": "long-form-list",
      "kicker": "SELECTED",
      "heading": "Featured Work",
      "rows": [
        {
          "id": "bnb-etl",
          "title": "ETL Pipeline Platform",
          "orgTag": "BNBUILDERS",
          "summary": "Production data infrastructure replacing a third-party SaaS sync tool.",
          "tags": ["C#", ".NET 10", "ASP.NET Core MVC", "T-SQL", "Azure SQL", "Oracle"],
          "description": "A .NET 10 ETL platform I built from scratch that moves hundreds of millions of rows a day from Oracle ERP into Azure SQL. ASP.NET Core MVC operator console for monitoring runs and queueing reruns.",
          "thumbnail": { "type": "svg-illustration", "concept": "abstract data-flow lines" },
          "repoUrl": null
        },
        {
          "id": "sha3",
          "title": "SHA3-SHAKE Cryptographic Library",
          "summary": "FIPS 202 compliant SHA-3 and SHAKE implementation in Java.",
          "tags": ["Java", "Cryptography", "FIPS 202", "SHA-3 / SHAKE"],
          "description": "SHA-3 and SHAKE implementation conforming to FIPS 202, with an optimized Keccak-f[1600] permutation. CLI for file hashing and MAC generation, validated against the full NIST test vector suite.",
          "thumbnail": { "type": "svg-illustration", "concept": "stylized hash block / Keccak sponge" },
          "repoUrl": "https://github.com/BigCatSoftware/sha3-shake-library"
        },
        {
          "id": "jminus",
          "title": "j-- Compiler Extensions",
          "summary": "Java-subset compiler extended across scanner, parser, and AST.",
          "tags": ["Java", "Compiler Design", "AST", "Parsing"],
          "description": "Extensions to a Java-subset compiler: scanner support for multi-line comments and numeric literals, additional grammar rules in the parser, and new AST nodes for conditionals, loops, and exception handling.",
          "thumbnail": { "type": "svg-illustration", "concept": "tokenized code snippet in JetBrains Mono on Surface0" },
          "repoUrl": "https://github.com/BigCatSoftware/j--"
        },
        {
          "id": "dungeon",
          "title": "Procedural Dungeon Generation",
          "summary": "LibGDX dungeon crawler with BSP-generated levels.",
          "tags": ["Java", "LibGDX", "BSP Algorithm", "Procedural Generation"],
          "description": "A LibGDX dungeon crawler with procedurally generated levels. A Binary Space Partitioning tree recursively subdivides a 50×50 grid into rectangular leaves; each leaf becomes a room, and doors are placed where adjacent rooms share a wall.",
          "thumbnail": { "type": "svg-illustration", "concept": "simplified BSP visualization, nested rectangles" },
          "repoUrl": "https://github.com/BigCatSoftware/Dungeon-Adventure"
        }
      ],
      "rowStyle": {
        "layout": "two-column: thumbnail ~30% / content ~70%",
        "verticalGap": "space-y-20",
        "thumbnailContainer": { "radius": "xl", "background": "surface", "padding": "p-8" },
        "hover": {
          "tilt":        { "enabled": true, "maxDeg": 6, "follow": "cursor", "spring": "springGentle" },
          "thumbBorder": "1px solid accent",
          "linkSlide":   "View source slides right 4px"
        }
      }
    },

    "TicTacToe": {
      "engine": "phaser-3",
      "renderingTarget": "2d-canvas",
      "kicker": "AN ASIDE",
      "heading": "Tic Tac Toe.",
      "leadIn": "Three in a row. You are X.",
      "scene": {
        "board": {
          "size": "3x3",
          "tileColor": "surface",
          "tileBorder": "1px solid surface2",
          "tileRadius": "md",
          "restingAnimation": "subtle breathing scale 1.0 to 1.02, staggered across tiles",
          "hover": {
            "tileScale": 1.05,
            "glow": "soft Lavender beneath tile"
          }
        },
        "pieces": {
          "X": {
            "color": "accent",
            "entrance": "drop with bounce, scale 0.3 to 1.1 to 1.0 over 280ms",
            "onPlace": "tile flashes accent briefly, click sound fires"
          },
          "O": {
            "color": "accent2",
            "entrance": "swirl in, rotation -180 to 0 plus scale 0 to 1 over 320ms",
            "onPlace": "tile flashes accent2 briefly, ai-click sound fires"
          }
        },
        "win": {
          "linePulse": "Lavender pulse travels along winning line, tile by tile",
          "shimmer": "winning tiles lift and shimmer after pulse",
          "particles": {
            "perTile": 18,
            "colors": ["accent", "accent2"],
            "trajectory": "hemisphere arc with gravity"
          },
          "cameraShake": { "amplitude": "6px", "duration": "220ms" }
        },
        "loss": "winning AI line shows desaturated grey, muted particles",
        "draw": "all tiles coordinated wiggle then settle",
        "thirdSessionWin": {
          "trigger": "session win count reaches 3",
          "modal": "VictoryMaster overlay (React, rendered above Phaser canvas)",
          "audio": "playVictorySounds() 2s after celebration",
          "counterPersists": false,
          "note": "counter is session-only React state; resets on page reload"
        }
      },
      "audio": {
        "ownership": "useSound hook in React; Phaser triggers via callbacks",
        "events": {
          "playerPlacesX":         "playClickSound(true)",
          "aiPlacesO":             "playClickSound(false) after 1s",
          "playerWins":            "playCelebrationSounds()",
          "thirdSessionWin":       "playVictorySounds() 2s after celebration",
          "victoryMasterBackdrop": "playVictorySounds() (mobile gesture replay)",
          "aiWins":                "silent",
          "draw":                  "silent",
          "newGame":               "silent"
        },
        "implementation": "ported verbatim from current oscillator/noise routines; do not re-bake or replace"
      },
      "controls": {
        "newGameButton": { "label": "New Game", "style": "ghost-outline", "behavior": "clears board and status, preserves session win counter" }
      },
      "accessibility": {
        "ariaLabel": "Interactive tic tac toe game",
        "skipLink":  "Keyboard-visible Skip Game link that anchors past the section"
      }
    },

    "Credentials": {
      "background": "accent",
      "kicker": "VERIFIABLE CREDENTIALS",
      "heading": "Credentials",
      "context": "B.S. Computer Science & Systems · University of Washington Tacoma · August 2025",
      "kickerColor": "bg",
      "headingColor": "bg",
      "contextColor": "bg-80",
      "widget": {
        "card": {
          "background": "surface",
          "radius": "2xl",
          "padding": "p-8 md:p-12",
          "maxWidth": "720px",
          "shadow": "lifted"
        },
        "credentialDisplay": {
          "label": { "content": "CREDENTIAL ID", "style": "kicker", "color": "textMuted" },
          "code":  { "content": "25C9-NTAN-TNRJ", "style": "credentialCode", "color": "accent" },
          "codeAnimation": "character-by-character fade-in on scroll into view, 60ms stagger left to right"
        },
        "statusLine": {
          "initial": { "content": "Awaiting verification...", "color": "textMuted" },
          "sequence": [
            { "content": "Connecting to UW Registrar...", "color": "textMuted",     "delayMs": 0 },
            { "content": "Validating credential ID...",   "color": "textMuted",     "delayMs": 400 },
            { "content": "Verified ✓",                    "color": "accent",        "delayMs": 800, "confetti": true }
          ]
        },
        "verifyButton": {
          "initial":    { "label": "Verify Credential", "style": "filled-accent2", "icon": "ShieldCheck" },
          "loading":    { "label": "Verifying...",      "style": "filled-accent2", "icon": "spinner",     "durationMs": 1200 },
          "completed":  { "label": "Open verification on UW Registrar →", "style": "filled-accent2", "icon": null, "href": "https://apps.registrar.washington.edu/cecredential/verify/", "target": "_blank", "rel": "noopener noreferrer" }
        },
        "footerCaption": { "content": "Verification powered by UW Registrar.", "style": "kicker", "color": "textMuted" }
      },
      "diploma": {
        "src": "/diploma_image.png",
        "alt": "Tiger Schueler's University of Washington Tacoma diploma.",
        "radius": "xl",
        "border": "1px solid surface2",
        "shadow": "soft",
        "position": "below widget on mobile, beside widget on md+"
      },
      "resume": {
        "embedDesktop": "<object data=\"/Tiger_Schueler_Software_Engineer_Resume.pdf\" type=\"application/pdf\"> with <iframe> fallback",
        "embedMobile":  "Open Resume card with FileText icon, opens PDF in new tab",
        "downloadButton": { "label": "Download PDF", "style": "filled-accent", "href": "/Tiger_Schueler_Software_Engineer_Resume.pdf", "downloadAttr": true },
        "position": "below widget, distinctly secondary"
      }
    },

    "Contact": {
      "heading": "Get In Touch",
      "subline": "For collaborations, hiring conversations, or just to say hello.",
      "links": [
        { "label": "Email",    "href": "mailto:tiger.schueler.dev@gmail.com",        "icon": "Mail",        "iconType": "lucide" },
        { "label": "LinkedIn", "href": "https://www.linkedin.com/in/tigerschueler/", "icon": "Linkedin",    "iconType": "lucide-or-inline" },
        { "label": "GitHub",   "href": "https://github.com/BigCatSoftware",           "icon": "GithubMark", "iconType": "inline-svg" }
      ],
      "linkStyle": "ghost-outline, Lavender border on hover, icon translate-y -2px on hover, 220ms"
    },

    "Footer": {
      "content": "Built by Tiger Schueler · React · Phaser · Tailwind · 2026",
      "techLinks": {
        "React":    "https://react.dev",
        "Phaser":   "https://phaser.io",
        "Tailwind": "https://tailwindcss.com"
      },
      "color": "textMuted",
      "alignment": "center",
      "size": "caption"
    }
  },

  "motionRules": {
    "entrance": {
      "trigger": "scroll into view, once per session",
      "transform": "translateY(16px) to translateY(0)",
      "opacity": "0 to 1",
      "durationMs": 600,
      "easing": "smoothOut",
      "stagger": "70-90ms between siblings"
    },
    "ambient": {
      "heroGradientDrift": "20s loop, animated background-position, low opacity"
    },
    "reducedMotion": {
      "behavior": "all motion collapsed to instant state changes",
      "hard-requirement": true
    }
  },

  "accessibility": {
    "wcagTarget": "AA",
    "lighthouseAccessibilityFloor": 95,
    "keyboardNavigable": true,
    "focusRingVisible": true,
    "skipLinks": ["Skip game (above Tic Tac Toe section)"],
    "altTextRequired": true,
    "decorativeElementsAriaHidden": true
  },

  "performance": {
    "lighthousePerformanceFloor": { "desktop": 90, "mobile": 80 },
    "lazyLoad": ["TicTacToe (Phaser section, via React.lazy + IntersectionObserver)", "Below-the-fold images"],
    "fontLoading": "font-display: swap with preconnect to Google Fonts",
    "noThirdPartyTrackers": true
  },

  "outOfScope": [
    "Top navigation bar",
    "Dark mode toggle",
    "Blog or writing section",
    "Social media embeds",
    "Custom cursor",
    "Page transitions (single-page site, N/A)",
    "Loading screens"
  ]
}
